---
import '../styles/index.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "新NISAに向けたシミュレーター。完全無料で高速に計算結果を表示します。",
	image = "/ogp-image.jpg" // 暫定画像パス
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://newnisa-simulator.com');
const safeTitle = title;

// Breadcrumb logic
const currentPath = Astro.url.pathname;
let currentName = "ホーム";
if (currentPath.includes('tsumitate')) currentName = "つみたてシミュレーター";
else if (currentPath.includes('withdraw')) currentName = "取り崩しシミュレーター";
else if (currentPath.includes('tax-compare')) currentName = "課税比較シミュレーター";
else if (currentPath.includes('ideco')) currentName = "iDeCo節税シミュレーター";
else if (currentPath.includes('account-compare')) currentName = "おすすめ証券口座比較";
else if (currentPath.includes('guide')) currentName = "新NISAガイド";
else if (currentPath.includes('/lp/')) currentName = "新NISA特集";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "ホーム",
      "item": "https://newnisa-simulator.com/"
    }
  ]
};

if (currentPath !== "/" && currentPath !== "") {
  breadcrumbSchema.itemListElement.push({
    "@type": "ListItem",
    "position": 2,
    "name": currentName,
    "item": `https://newnisa-simulator.com${currentPath}`
  });
}
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{safeTitle}</title>
		
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph Tags -->
		<meta property="og:title" content={safeTitle} />
		<meta name="google-site-verification" content="PKKOFXFOmFjTUktRGcogONs_PJHt4Gd58md9RA9m2ss" />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<!-- Google Fonts for modern typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<style>
			.header-container {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 1rem;
				flex-wrap: wrap;
				margin-bottom: 2rem;
			}
			.header-title-area {
				flex: 1;
			}
			.header-back-btn {
				padding: 0.5rem 1rem;
				font-size: 0.85rem;
				border: 1px solid var(--border-color);
				border-radius: 4px;
				color: var(--text-main);
				text-decoration: none;
				white-space: nowrap;
				transition: background-color 0.2s;
			}
			.header-back-btn:hover {
				background-color: var(--border-color);
			}
			@media (max-width: 640px) {
				.header-container {
					flex-direction: column;
					align-items: center;
					text-align: center;
				}
				.header-title-area {
					width: 100%;
				}
				.header-back-btn {
					margin-top: 0.5rem;
				}
			}
		</style>
		<main class="container">
			<header class="header-container">
				<div class="header-title-area">
					<a href="/" style="text-decoration: none;">
						<h1>新NISAシミュレーター</h1>
					</a>
					<p class="subtitle">積立・取り崩し・課税口座比較に対応した資産計算ツール</p>
				</div>
				<a href="/" class="header-back-btn">TOPへ戻る</a>
			</header>

            {currentPath !== "/" && currentPath !== "" && (
            <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2rem; background: var(--bg-body); padding: 0.5rem 1rem; border-radius: 4px; display: inline-block;">
                <a href="/" style="color: var(--primary); text-decoration: underline; font-weight: bold;">TOP</a> <span style="margin: 0 0.5rem;">&gt;</span> <span style="font-weight: 500;">{currentName}</span>
            </div>
            )}

			<nav class="nav-links">
				<a href="/" class={`nav-link track-nav ${Astro.url.pathname === '/' ? 'active' : ''}`} data-nav="home">ホーム</a>
				<a href="/nisa-tsumitate" class={`nav-link track-nav ${Astro.url.pathname.includes('tsumitate') ? 'active' : ''}`} data-nav="tsumitate">つみたて</a>
				<a href="/nisa-withdraw" class={`nav-link track-nav ${Astro.url.pathname.includes('withdraw') ? 'active' : ''}`} data-nav="withdraw">取り崩し</a>
				<a href="/nisa-tax-compare" class={`nav-link track-nav ${Astro.url.pathname.includes('tax-compare') ? 'active' : ''}`} data-nav="tax-compare">課税比較</a>
				<a href="/ideco-simulator/" class={`nav-link track-nav ${Astro.url.pathname.includes('ideco') ? 'active' : ''}`} data-nav="ideco">iDeCo</a>
				<a href="/account-compare" class={`nav-link track-nav ${Astro.url.pathname.includes('account-compare') ? 'active' : ''}`} data-nav="compare">口座比較</a>
				<a href="/new-nisa-guide/" class={`nav-link track-nav ${Astro.url.pathname.includes('new-nisa-guide') ? 'active' : ''}`} data-nav="guide">新NISAとは</a>
			</nav>

			<slot />

			<footer style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border-color); text-align: center; color: var(--text-muted); font-size: 0.9rem; padding-bottom: 2rem;">
				<div style="display: flex; justify-content: center; gap: 1.5rem; margin-bottom: 1rem;">
					<a href="/privacy" style="color: var(--text-muted); text-decoration: none;">プライバシーポリシー</a>
					<a href="/about" style="color: var(--text-muted); text-decoration: none;">運営者情報</a>
					<a href="/disclaimer" style="color: var(--text-muted); text-decoration: none;">免責事項</a>
				</div>
				<p>&copy; {new Date().getFullYear()} 新NISAシミュレーター All Rights Reserved.</p>
			</footer>
		</main>

		<script>
		  function trackEvent(name, params = {}) {
		    try {
		      const gtag = globalThis.gtag;
		      if (typeof gtag === "function") gtag("event", name, params);
		    } catch (e) {}
		  }

		  // Track navigation clicks
		  document.addEventListener('DOMContentLoaded', () => {
			const navLinks = document.querySelectorAll('.track-nav');
			navLinks.forEach(link => {
			  link.addEventListener('click', (e) => {
				const navTarget = link.getAttribute('data-nav');
				if (navTarget === 'home') {
					trackEvent('nav_home_click');
				} else {
					trackEvent('nav_click', { target: navTarget });
				}
			  });
			});
		  });
		</script>
	</body>
</html>
