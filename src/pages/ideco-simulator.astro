---
import Layout from '../layouts/Layout.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import FAQSection from '../components/FAQSection.astro';

const title = "新NISAとiDeCoどっち？違いと向き不向きを比較【無料試算】";
const description =
  "新NISAとiDeCo（イデコ）は結局どちらがおすすめなのか？あなたの年収と毎月の掛金を入力するだけで、iDeCoによる毎年の節税額（所得控除）を無料でシミュレーション。それぞれの制度の違いやメリット・デメリットを比較し最適な活用法を検討できます。";

const faqs = [
  { q: "iDeCoと新NISAはどう使い分けるべきですか？", a: "一般的に、60歳まで引き出せない制約を許容でき、毎年の所得税・住民税を減らしたい場合はiDeCoを優先、いつでも資金を引き出して柔軟に使いたい場合は新NISAを優先するのが選択肢となります。" },
  { q: "iDeCoの掛金は誰でも上限が同じですか？", a: "いいえ、職業（会社員・公務員・自営業など）や加入している企業年金の有無によって、月々の拠出限度額が1.2万円〜6.8万円まで異なります。" },
  { q: "専業主婦（主夫）でもiDeCoの節税メリットはありますか？", a: "iDeCoの最大のメリットは「所得控除」による税金軽減ですが、ご本人に課税所得がない場合、この所得控除の恩恵は受けられません。その場合は新NISAの方が向いているケースがあります。" }
];

const buildDate = new Date().toLocaleDateString('ja-JP', { timeZone: 'Asia/Tokyo' });
---

<Layout title={title} description={description}>
    <div style="margin-bottom: 2.5rem;">
      <h1 style="font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; color: var(--text-main);">iDeCo（イデコ）節税シミュレーター</h1>

      <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.25rem;">
          <span>🔄 最終更新日: {buildDate}</span>
      </div>
      
      <div style="font-size: 0.95rem; margin-bottom: 1.5rem;">
          💡 <a href="/new-nisa-guide/" class="track-nav" data-nav="ideco_guide" style="color: var(--primary); font-weight: bold; text-decoration: underline;">制度の詳細はこちら → 新NISA完全ガイド</a>
      </div>
      <p style="margin: 0 0 16px; line-height: 1.8; color: var(--text-muted); font-size: 0.95rem;">
        iDeCo（個人型確定拠出年金）制度を利用した場合の、将来の資産推移と掛金拠出による毎年の「所得控除（概算節税額）」を同時に計算できる無料シミュレーションツールです。
        掛金全額が非課税となるiDeCo特有のメリットを視覚化し、新NISAなど他の制度と比較検討する材料として役立ちます。
        実効税率（所得税＋住民税の目安）を選択することでご自身の年収帯に近い条件での節税インパクトの確認が可能です。<br/>
        ※各種税額は簡便的な計算に基づく参考値・概算値であり、個別の控除状況等を反映した正確な税額算出や投資助言を提供するものではありません。
      </p>

      <div style="margin-bottom: 1.5rem; padding: 1rem; background-color: #f0fdf4; border-radius: 8px; border-left: 4px solid #10b981; font-size: 0.9rem;">
        <p style="margin: 0 0 0.5rem; font-weight: bold; color: var(--text-main);">💡 まずはどう入力すればいい？</p>
        <p style="margin: 0; color: var(--text-muted);">迷ったら <strong>掛金 23,000円 / 運用期間 20年 / 想定年利 4.0%</strong> で試算してみてください。<br/>※ iDeCoは原則60歳まで引き出し制限があります。</p>
      </div>

      <section style="border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; background-color: white; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
