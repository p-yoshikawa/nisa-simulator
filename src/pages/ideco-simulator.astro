            <button type="button" onclick="document.getElementById('monthly').value=68000; document.getElementById('years').value=20; document.getElementById('rate').value=4.0; document.getElementById('taxRate').value=20; render();" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 4px; border: 1px solid var(--primary); background: white; color: var(--primary); cursor: pointer; font-weight: bold;">自営業向け (月6.8万)</button>
        </div>

        <div style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
