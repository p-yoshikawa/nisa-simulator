---
import Layout from '../layouts/Layout.astro';
import CalculatorForm from '../components/CalculatorForm.tsx';
import RelatedLinks from '../components/RelatedLinks.astro';
import FAQSection from '../components/FAQSection.astro';

const faqs = [
  { q: "新NISAのつみたて投資枠はいくらから始められますか？", a: "金融機関によって異なりますが、主要なネット証券などでは月額100円といった少額から無理なく始めることができます。" },
  { q: "想定利回りは何％で計算するのが現実的ですか？", a: "投資対象や相場環境により異なりますが、全世界株式などのインデックスファンドに長期投資する場合、一般的に年利3〜5％程度を目安に試算されることが多いです。" },
  { q: "途中で積立金額を変更、またはやめることはできますか？", a: "はい、多くの場合Web上からいつでも積立金額の増減や、一時停止、再開の手続きが可能です。家計の状況に合わせて調整できます。" }
];

const buildDate = new Date().toLocaleDateString('ja-JP', { timeZone: 'Asia/Tokyo' });
---

<Layout 
	title="新NISA積立シミュレーション｜毎月いくらで将来いくら？【無料】" 
	description="新NISAで毎月いくら積み立てれば将来いくらになるのか？期待利回りや積立期間を入力するだけで、将来の資産予想を完全無料でシミュレーションできます。目標金額に向けた毎月の必要額も計算可能。まずはあなたの条件でグラフを確認してみましょう。"
>
	<div style="margin-bottom: 2.5rem;">
		<h1 style="font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; color: var(--text-main);">つみたてNISA（積立投資）シミュレーター</h1>

        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.25rem;">
            <span>🔄 最終更新日: {buildDate}</span>
        </div>
        
        <div style="font-size: 0.95rem; margin-bottom: 1.5rem;">
            💡 <a href="/new-nisa-guide/" class="track-nav" data-nav="tsumitate_guide" style="color: var(--primary); font-weight: bold; text-decoration: underline;">制度の詳細はこちら → 新NISA完全ガイド</a>
        </div>
		<p style="margin: 0 0 1rem; line-height: 1.8; color: var(--text-muted); font-size: 0.95rem;">
			「毎月の積立金額」「想定される年利（利回り）」「運用期間」の3つの項目を入力するだけで、長期間運用を継続した場合の資産合計額をシミュレーションします。
			新NISAの「つみたて投資枠」を利用して毎月コツコツと均等額で投資信託などを買い付けた場合、
			投資した元本が長期的な複利効果によりどのように推移するかをグラフと数値で可視化します。
			ボーナス月などの増額設定は省いたシンプルな概算ツールとして、将来の目標金額に向けた積立ペースの参考にご利用ください。<br/>
			※初期設定値は参考例であり、将来の運用成果を保証するものではありません。
		</p>
	</div>

	<!-- client:load を使用して即時インタラクティブに。グラフ自体は内部でReact.lazyによる遅延ロードが行われます -->
	<CalculatorForm mode="tsumitate" client:load />

	<section class="card" style="margin-top: 3rem; margin-bottom: 2rem; border-color: rgba(37, 99, 235, 0.2); background-color: #f8fafc;">
		<h3 style="font-size: 1.25rem; margin-bottom: 1rem; color: var(--text-main);">iDeCoとの違いも比較できます</h3>
		<p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6;">
			iDeCoは掛金が全額所得控除になる制度です。<br/>
			60歳まで引き出せない代わりに、節税という非常に大きなメリットがあります。<br/>
			ご自身の年収や掛金でどのくらいの節税効果があるか試算してみましょう。
		</p>
		<div style="text-align: center;">
			<a href="/ideco-simulator/" class="nav-link track-nav" data-nav="ideco_cta" style="display: inline-block; background-color: var(--primary); color: white; padding: 1rem 2rem; border-radius: 8px; font-weight: bold; text-decoration: none; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
				iDeCoの効果をシミュレーションする
			</a>
		</div>
	</section>

    <section class="card" style="margin-bottom: 2.5rem; background-color: white; border: 1px solid var(--border-color);">
        <h2 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main);">新NISAのつみたて投資枠は毎月いくら設定するのがおすすめ？</h2>
        <p style="line-height: 1.8; color: var(--text-muted); font-size: 0.95rem; margin: 0;">
            新NISAの「つみたて投資枠」を利用して資産運用を始める際、多くの方が悩むのが「毎月いくら積み立てるべきか」という設定金額です。つみたて投資の基本は、ご自身の収入と毎月の固定費を見直した上で「相場が下落したとしても無理なく長期間続けられる余剰資金」を設定することにあります。例えば、毎月3万円であっても、年利5%（仮定）で20年間運用し続ければ、複利効果によって元本を大きく上回る評価額になる可能性があることが当シミュレーターから確認できます。早く非課税枠を埋めることにとらわれず、ご自身のペースで将来予測を立てながら、ライフステージの変化に合わせて積立金額を柔軟に見直していくことが大切です。
        </p>
    </section>

    <!-- 新設： 目的別・詳細解説へのリンク集 -->
    <section style="margin-bottom: 2rem; background-color: white; padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color);">
        <h2 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">
            年代別に試算する
        </h2>
        <ul style="list-style-type: none; padding: 0; display: flex; flex-direction: column; gap: 0.8rem;">
            <li><a href="/lp/30s-how-much" style="color: var(--primary); text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;"><span>▶</span> 30代で始める場合の目安を見る</a></li>
            <li><a href="/lp/40s-is-it-late" style="color: var(--primary); text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;"><span>▶</span> 40代からのスタートでも間に合うか確認する</a></li>
        </ul>
        <h2 style="font-size: 1.1rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 1rem; color: var(--text-main); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">
            金額別に試算する
        </h2>
        <ul style="list-style-type: none; padding: 0; display: flex; flex-direction: column; gap: 0.8rem;">
            <li><a href="/lp/monthly-30000-future" style="color: var(--primary); text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;"><span>▶</span> 月3万円の積立で将来どうなるか見る</a></li>
        </ul>
    </section>

	<RelatedLinks />
	<FAQSection faqs={faqs} />
</Layout>
