---
import Layout from '../layouts/Layout.astro';
import CalculatorForm from '../components/CalculatorForm.tsx';
import RelatedLinks from '../components/RelatedLinks.astro';
import FAQSection from '../components/FAQSection.astro';

const faqs = [
  { q: "老後に資産を取り崩す際、税金はかかりますか？", a: "新NISA口座内で運用・売却（取り崩し）する場合は、運用益に対して税金はかからず、全額を手元に残すことができます。" },
  { q: "資産寿命を延ばすためのポイントは何ですか？", a: "引き出し額を完全に固定するのではなく、運用利回りより少ない金額（例: 資産残高の4%など）を取り崩すことで、資産が枯渇するスピードを一定に抑えられやすくなります。" },
  { q: "想定利回りをマイナスに設定することは可能ですか？", a: "ツール上はマイナス利回りでの計算にも対応しています。相場下落リスクを考慮した悲観シナリオとして活用いただけます。" }
];
---

<Layout 
	title="新NISA取り崩しシミュレーター【無料】老後・FIREの資産寿命計算" 
	description="FIREや老後生活に向けて運用しながら毎月定額を取り崩した場合の資産寿命を無料で即時計算。運用利回りと引出額から推移をグラフ化します。"
>
	<div style="margin-bottom: 2.5rem;">
		<h1 style="font-size: 1.8rem; font-weight: 800; margin: 0 0 1rem; color: var(--text-main);">資産取り崩し（出口戦略）シミュレーター</h1>
		<p style="margin: 0 0 1rem; line-height: 1.8; color: var(--text-muted); font-size: 0.95rem;">
			すでに形成した資産を運用しながら毎月一定額を取り崩していく「出口戦略」のための無料シミュレーターです。
			現在の資産額、想定される運用利回り、そして毎月の目標引き出し額を入力することで、資産が底をつくまでの期間（資産寿命）や推移をグラフ上で可視化します。
			FIRE（経済的自立と早期退職）後の資金計画や、リタイア・老後の年金プラスアルファの生活費計算など、ライフプランのベースとなる概算把握にお役立てください。
			新NISAを活用し非課税で引き出す設定の目安としてもご利用いただけます。<br/>
			※税金や手数料は考慮しておらず、将来の資産寿命を満額保証するものではありません。
		</p>
	</div>

	<CalculatorForm mode="withdraw" client:load />

	<RelatedLinks />
	<FAQSection faqs={faqs} />
</Layout>
