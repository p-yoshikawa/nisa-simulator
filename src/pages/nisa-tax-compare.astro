---
import Layout from '../layouts/Layout.astro';
import CalculatorForm from '../components/CalculatorForm.tsx';
import RelatedLinks from '../components/RelatedLinks.astro';
import FAQSection from '../components/FAQSection.astro';

const faqs = [
  { q: "新NISAと特定口座の主な違いは何ですか？", a: "最大の違いは売却時や配当金に対する税金です。特定口座では約20%の税金が引かれますが、新NISAでは制限枠内であれば利益が非課税になります。" },
  { q: "複数の証券会社で新NISA口座を持つことはできますか？", a: "新NISA口座は原則として1人1口座しか開設できません。金融機関の変更は年ごとに可能ですが、口座の併用は不可となります。" },
  { q: "iDeCoと新NISAは併用できますか？", a: "はい、可能です。iDeCoは掛金自体が所得控除の対象となるため税効果はさらに高まりますが、60歳までの引き出し制限があります。目的に応じて使い分けてください。" }
];
---

<Layout 
	title="新NISA・課税口座比較シミュレーター【無料】節税効果と手取り計算" 
	description="新NISA（非課税）と特定口座（課税口座）の手取り額の違いを無料でシミュレーション。約20%の税金分がどれほど有利になるかグラフで比較します。"
>
	<div style="margin-bottom: 2.5rem;">
		<h1 style="font-size: 1.8rem; font-weight: 800; margin: 0 0 1rem; color: var(--text-main);">NISA vs 課税口座 比較シミュレーター</h1>
		<p style="margin: 0 0 1rem; line-height: 1.8; color: var(--text-muted); font-size: 0.95rem;">
			同じ金額・利回りで運用した際に、利益に税金がかからない「新NISA口座」と、売却益に約20.315%の税金がかかる「通常の課税口座（特定口座など）」での手取り額の差を算出する無料ツールです。
			長期運用における節税効果の大きさを棒グラフで視覚的に比較できるため、NISA制度を利用するメリットを具体的な数値感として把握できます。
			毎月の積立額と期間を入力するだけで、将来どれだけの税金が掛かる（または免除される）のかを即座に確認可能です。<br/>
			※計算結果は現行の税制に基づいたシミュレーション用の概算値であり、今後の制度・税率変更等を反映または保証するものではありません。
		</p>
	</div>

	<CalculatorForm mode="tax-compare" client:load />

	<section class="card" style="margin-top: 3rem; margin-bottom: 2rem; border-color: rgba(37, 99, 235, 0.2); background-color: #f8fafc;">
		<h3 style="font-size: 1.25rem; margin-bottom: 1rem; color: var(--text-main);">さらなる節税なら「iDeCo」も比較できます</h3>
		<p style="color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6;">
			NISAは利益そのものが非課税になる仕組みですが、iDeCoはそれに加えて<strong>掛金が全額所得控除（税金が安くなる）</strong>になる強力な節税メリットがあります。<br/>
			ご自身の年収や掛金でどのくらいの節税効果があるか試算してみましょう。
		</p>
		<div style="text-align: center;">
			<a href="/ideco-simulator/" class="nav-link track-nav" data-nav="ideco_cta" style="display: inline-block; background-color: var(--primary); color: white; padding: 1rem 2rem; border-radius: 8px; font-weight: bold; text-decoration: none; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
				iDeCoの効果をシミュレーションする
			</a>
		</div>
	</section>

	<RelatedLinks />
	<FAQSection faqs={faqs} />
</Layout>
