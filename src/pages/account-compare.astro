---
import Layout from '../layouts/Layout.astro';
import AffiliateSection from '../components/AffiliateSection.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import FAQSection from '../components/FAQSection.astro';
import { getBrokerUrl } from '../lib/affiliates';

const isAffiliateMode = import.meta.env.PUBLIC_AFFILIATE_MODE === 'on';
const sbiUrl = getBrokerUrl('sbi-neotrade');
const matsuiUrl = getBrokerUrl('matsui');

const faqs = [
  { q: "証券口座の開設に費用はかかりますか？", a: "主要なネット証券など、多くの金融機関では口座開設費用や維持手数料は無料に設定されています。" },
  { q: "複数の証券口座で新NISAを同時に利用できますか？", a: "新NISA口座はいずれか1つの金融機関でしか開設・利用できません。通常の課税口座（特定口座など）であれば、複数の証券会社で同時に持つことが可能です。" },
  { q: "初心者にはどのような証券会社がおすすめですか？", a: "一般的に、売買手数料が無料であること、投資信託の取扱銘柄が多いこと、100円などの少額から積立できるネット証券が、初心者の方にとって始めやすいとされています。" }
];

const buildDate = new Date().toLocaleDateString('ja-JP', { timeZone: 'Asia/Tokyo' });
---

<Layout 
	title="新NISAおすすめ証券口座比較【無料】手数料・特徴まとめ" 
	description="新NISA口座選びの参考になる証券会社の比較情報です。取扱商品数や手数料の観点から各社のおすすめポイントを整理しました。"
>
	<div style="margin-bottom: 2.5rem;">
		<h1 style="font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; color: var(--text-main);">新NISA口座選び・証券会社比較</h1>

        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.25rem;">
            <span>🔄 最終更新日: {buildDate}</span>
        </div>
        
        <div style="font-size: 0.95rem; margin-bottom: 1.5rem;">
            💡 <a href="/new-nisa-guide/" class="track-nav" data-nav="compare_guide" style="color: var(--primary); font-weight: bold; text-decoration: underline;">制度の詳細はこちら → 新NISA完全ガイド</a>
        </div>

		<p style="font-size: 0.8rem; color: var(--text-muted); margin: 0 0 1rem 0;">※本ページにはプロモーションが含まれます。</p>
		<p style="margin: 0 0 1rem; line-height: 1.8; color: var(--text-muted); font-size: 0.95rem;">
			これから新NISAやiDeCoを始める方に向け、取引手数料が無料で投資信託の取扱数が多い代表的なネット証券のサービス内容をまとめた比較情報です。
			証券口座を開設維持し資金を運用する際にかかるコスト体系や、取り扱っている金融商品の充実度、スマートフォンでの操作性やポイント還元などの付加価値を軸に紹介しています。
			各社の強みを確認しながら、ご自身の投資スタイルや目的・重視するポイントに合わせて最適な証券口座を見つけるための参考にしてください。<br/>
			※本情報は各社の公式サイト等に基づくものであり、特定の口座開設を強く推奨したり、運用成果を保証するものではありません。
		</p>
	</div>

    <!-- Comparison Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
        
        <!-- SBIネオトレード証券 -->
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column;">
            <h3 style="font-size: 1.3rem; margin-bottom: 1rem; color: var(--primary); text-align: center;">SBIネオトレード証券</h3>
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem; margin-bottom: 1.5rem;">
                <tbody>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal; width: 40%;">取引手数料</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">0円（完全無料）</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal;">取扱商品</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">厳選された投資信託</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal;">最低積立額</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">100円</td>
                    </tr>
                    <tr>
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal;">サポート体制</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">オンライン/電話</td>
                    </tr>
                </tbody>
            </table>
            <div style="margin-top: auto;">
                <a href={sbiUrl} target="_blank" rel="nofollow noopener noreferrer" class="track-affiliate" data-broker="sbi-neotrade_card" style="display: block; text-align: center; padding: 1rem; background-color: var(--primary); color: white; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 1rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                    公式サイトで詳細を見る（PR）
                </a>
            </div>
        </div>

        <!-- 松井証券 -->
        <div style="background: white; border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column;">
            <h3 style="font-size: 1.3rem; margin-bottom: 1rem; color: var(--primary); text-align: center;">松井証券</h3>
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem; margin-bottom: 1.5rem;">
                <tbody>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal; width: 40%;">取引手数料</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">0円（完全無料）</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal;">取扱商品</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">投資信託 約2,000本超</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal;">最低積立額</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">100円</td>
                    </tr>
                    <tr>
                        <th style="padding: 0.75rem 0; color: var(--text-muted); font-weight: normal;">サポート体制</th>
                        <td style="padding: 0.75rem 0; color: var(--text-main); font-weight: bold; text-align: right;">充実（有人チャット等）</td>
                    </tr>
                </tbody>
            </table>
            <div style="margin-top: auto;">
                <a href={matsuiUrl} target="_blank" rel="nofollow noopener noreferrer" class="track-affiliate" data-broker="matsui_card" style="display: block; text-align: center; padding: 1rem; background-color: var(--primary); color: white; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 1rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                    公式サイトで詳細を見る（PR）
                </a>
            </div>
        </div>

    </div>

    <!-- Recommendation Engine -->
    <div class="card" id="reco-quiz" style="margin-bottom: 2rem; background-color: #f0fdf4; border-color: #bbf7d0;">
        <h3 style="font-size: 1.25rem; margin-bottom: 1rem; color: var(--text-main); text-align: center;">あなたにぴったりの証券会社は？ 簡易診断</h3>
        
        <div id="quiz-q1" class="quiz-question" style="text-align: center;">
            <p style="font-weight: bold; margin-bottom: 1rem;">Q1. あなたの投資経験は？</p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <button type="button" class="quiz-btn" data-target="q2" data-score="sbi" style="padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid var(--primary); background: white; cursor: pointer; color: var(--primary); font-weight: bold;">初心者</button>
                <button type="button" class="quiz-btn" data-target="q2" data-score="matsui" style="padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid var(--primary); background: white; cursor: pointer; color: var(--primary); font-weight: bold;">ある程度経験あり</button>
            </div>
        </div>

        <div id="quiz-q2" class="quiz-question" style="display: none; text-align: center;">
            <p style="font-weight: bold; margin-bottom: 1rem;">Q2. メインで考えている投資対象は？</p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <button type="button" class="quiz-btn" data-target="q3" data-score="matsui" style="padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid var(--primary); background: white; cursor: pointer; color: var(--primary); font-weight: bold;">つみたて中心</button>
                <button type="button" class="quiz-btn" data-target="q3" data-score="sbi" style="padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid var(--primary); background: white; cursor: pointer; color: var(--primary); font-weight: bold;">個別株等も積極的に</button>
            </div>
        </div>

        <div id="quiz-q3" class="quiz-question" style="display: none; text-align: center;">
            <p style="font-weight: bold; margin-bottom: 1rem;">Q3. 証券会社選びで一番重視するのは？</p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <button type="button" class="quiz-btn" data-target="result" data-score="sbi" style="padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid var(--primary); background: white; cursor: pointer; color: var(--primary); font-weight: bold;">とにかく手数料の安さ</button>
                <button type="button" class="quiz-btn" data-target="result" data-score="matsui" style="padding: 0.75rem 1.5rem; border-radius: 8px; border: 1px solid var(--primary); background: white; cursor: pointer; color: var(--primary); font-weight: bold;">使いやすさ・サポート</button>
            </div>
        </div>

        <div id="quiz-result" class="quiz-question" style="display: none; text-align: center;">
            <p style="font-weight: bold; margin-bottom: 1rem; color: var(--text-muted);">診断結果</p>
            <h4 style="font-size: 1.5rem; color: var(--primary); margin-bottom: 1rem;">おすすめ：<span id="reco-name">---</span></h4>
            <p id="reco-reason" style="margin-bottom: 1.5rem; color: var(--text-main);"></p>
            
            <a id="reco-cta" href="#" target="_blank" rel="nofollow noopener noreferrer" style="display: inline-block; background-color: var(--primary); color: white; padding: 1rem 2rem; border-radius: 8px; font-weight: bold; text-decoration: none; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); margin-bottom: 1rem;">
                今すぐ口座開設へ進む
            </a>
            <br/>
            <a id="reco-alt" href="#" target="_blank" rel="nofollow noopener noreferrer" style="color: var(--text-muted); text-decoration: underline; font-size: 0.9rem;">
                もう一つのおすすめ（<span id="alt-name">---</span>）も確認する
            </a>
        </div>
    </div>

    <div class="card" style="margin-bottom: 2rem;">
        <h3 style="font-size: 1.25rem; margin-bottom: 1rem; color: var(--text-main);">主要な証券会社の特徴</h3>
        <ul style="list-style-type: disc; padding-left: 1.5rem; color: var(--text-muted); line-height: 1.8;">
            <li><strong style="color: var(--text-main);">SBIネオトレード証券</strong>：手数料の安さが魅力。これから投資を始める初心者におすすめです。</li>
            <li><strong style="color: var(--text-main);">松井証券</strong>：新NISAに対応しており、初心者でも始めやすいサポート体制が魅力です。</li>
        </ul>
        <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--text-muted);">
            ※当サイトの比較情報は参考情報であり、投資助言を目的としたものではありません。投資に関する最終決定は、ご自身のご判断にてお願いいたします。
        </p>
    </div>

    <div style="margin-bottom: 2.5rem; text-align: center;">
        <p style="font-size: 0.95rem; color: var(--text-main); margin-bottom: 0.5rem; font-weight: bold;">💡 NISAと並行して人気の「iDeCo」の将来資産も試算できます</p>
        <a href="/ideco-simulator/" class="track-nav" data-nav="ideco_compare" style="color: var(--primary); text-decoration: underline; font-weight: bold;">
            iDeCoシミュレーターへ
        </a>
    </div>

    <section class="card" style="margin-bottom: 2.5rem; background-color: white; border: 1px solid var(--border-color);">
        <h2 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main);">新NISA口座のおすすめ証券会社の選び方とネット証券のメリット</h2>
        <p style="line-height: 1.8; color: var(--text-muted); font-size: 0.95rem; margin: 0;">
            新NISAの口座は1人につき1つの金融機関でしか開設できないため、どこを選ぶかは非常に迷うポイントです。初心者の方をはじめ、長期的な資産形成を目指す多くの方におすすめされているのが「ネット証券」です。ネット証券は実店舗を持たないため運営コストが低く、投資信託の買付手数料が無料（ノーロード）であったり、保有期間中にかかる信託報酬が業界最安水準の優良ファンドを多数取り扱っていたりするという大きな強みがあります。また、スマートフォン一つで口座開設から積立設定まで完結し、画面も見やすく設計されています。当ページで比較している証券会社を中心に、ご自身の投資スタイルや目的（とにかく手数料を抑えたい、初心者向けのサポート体制を重視したい等）に合わせて、最適なネット証券を探してみてください。
        </p>
    </section>

    <!-- DMM株 特化セクション -->
    <section class="card" style="margin-bottom: 2.5rem; background-color: var(--bg-body); border: none;">
        <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main); text-align: center;">米国株やアプリ取引を中心に利用したい方向け</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.8;">
            新NISA口座選びにおいて、「米国株（個別株）の手数料」や「スマートフォンの取引アプリの使いやすさ」を最も重視する方向けの選択肢として、DMM株（DMM.com証券）が挙げられます。
        </p>
        
        <div style="background-color: white; border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem;">
            <h4 style="font-size: 1.1rem; color: var(--text-main); margin-bottom: 0.5rem;">📱 特徴（事実情報）</h4>
            <ul style="list-style-type: disc; padding-left: 1.5rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; font-size: 0.95rem;">
                <li>国内株式だけでなく、米国株式の取引手数料も一律無料（※為替手数料は別途かかります）</li>
                <li>PC並みの機能を持つスマートフォン専用の取引アプリ（かんたんモード/ノーマルモード切替対応）</li>
                <li>24時間対応のLINEカスタマーサポート</li>
            </ul>

            <h4 style="font-size: 1.1rem; color: var(--text-main); margin-bottom: 0.5rem; margin-top: 1.5rem;">👤 向いている人</h4>
            <ul style="list-style-type: disc; padding-left: 1.5rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 1rem; font-size: 0.95rem;">
                <li>投資信託の積立だけでなく、日米の個別株取引をスマホ中心でアクティブに行いたい方</li>
            </ul>

            <h4 style="font-size: 1.1rem; color: var(--text-main); margin-bottom: 0.5rem; margin-top: 1.5rem;">⚠️ 注意点</h4>
            <ul style="list-style-type: disc; padding-left: 1.5rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 0; font-size: 0.95rem;">
                <li>投資信託の取り扱い銘柄数が、SBI証券や楽天証券などの大手ネット証券と比較して限定的です。</li>
                <li>「低コストなインデックスファンドをひたすら積み立てたい」という目的の方には不向きな場合があります。</li>
            </ul>
        </div>

        <div style="text-align: center;">
            <a href="https://px.a8.net/svt/ejp?a8mat=4AXL46+2ZRH9U+1WP2+15R4NM" target="_blank" rel="nofollow noopener noreferrer" class="track-outbound" data-target="dmm_stock" style="display: inline-block; background-color: var(--primary); color: white; padding: 1rem 2.5rem; border-radius: 8px; font-weight: bold; text-decoration: none; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                公式サイトで詳細を見る（PR）
            </a>
            <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--text-muted);">※DMM.com証券のページへ遷移します。</p>
        </div>
    </section>

	<AffiliateSection placement="compare_page" />
    <RelatedLinks />
    <FAQSection faqs={faqs} />

    <script is:inline define:vars={{ sbiUrl, matsuiUrl, isAffiliateMode }}>
        function trackEvent(name, params = {}) {
            try {
                const gtag = window.gtag;
                if (typeof gtag === "function") gtag("event", name, params);
            } catch (e) {}
        }

        document.addEventListener("DOMContentLoaded", () => {
            console.log("[quiz] script loaded");

            // Static broker info instead of import
            const brokers = {
                'sbi': {
                    id: 'sbi-neotrade',
                    name: 'SBIネオトレード証券',
                    reason: '低コストで取引可能なので、手数料を重視してアクティブに投資したい方に最適です。',
                    active: isAffiliateMode,
                    url: sbiUrl
                },
                'matsui': {
                    id: 'matsui',
                    name: '松井証券',
                    reason: '初心者に優しいサポート体制があり、新NISAで安心して長期運用したい方に最適です。',
                    active: isAffiliateMode,
                    url: matsuiUrl
                }
            };

            let scores = { sbi: 0, matsui: 0 };
            const quizContainer = document.getElementById('reco-quiz');
            
            if (!quizContainer) return;

            quizContainer.addEventListener('click', (e) => {
                const btn = e.target.closest('.quiz-btn');
                if (!btn) return;

                const scoreKey = btn.getAttribute('data-score');
                const targetId = btn.getAttribute('data-target');
                
                if (scoreKey === 'sbi') scores.sbi++;
                if (scoreKey === 'matsui') scores.matsui++;

                btn.classList.add('is-active');

                const currentQuestion = btn.closest('.quiz-question');
                if (currentQuestion) {
                    currentQuestion.style.display = 'none';
                }

                console.log("[quiz] answered", scoreKey, "Current scores:", scores, "Next Target:", targetId);

                if (targetId === 'result') {
                    showResult();
                } else {
                    const nextQ = document.getElementById('quiz-' + targetId);
                    if (nextQ) nextQ.style.display = 'block';
                }
            });

            function showResult() {
                const recoKey = scores.sbi >= scores.matsui ? 'sbi' : 'matsui';
                const altKey = scores.sbi >= scores.matsui ? 'matsui' : 'sbi';
                const recoBroker = brokers[recoKey];
                const altBroker = brokers[altKey];

                document.getElementById('reco-name').textContent = recoBroker.name;
                document.getElementById('alt-name').textContent = altBroker.name;
                document.getElementById('reco-reason').textContent = recoBroker.reason;

                const recoCta = document.getElementById('reco-cta');
                recoCta.href = recoBroker.url;
                recoCta.textContent = recoBroker.active ? '口座開設ページへ進む' : '公式サイトで確認';

                const recoAlt = document.getElementById('reco-alt');
                recoAlt.href = altBroker.url;

                document.getElementById('quiz-result').style.display = 'block';

                trackEvent('account_compare_reco_shown', { reco: recoBroker.id });

                recoCta.addEventListener('click', () => {
                    trackEvent('account_compare_cta_click', { reco: recoBroker.id, broker: recoBroker.id });
                });

                recoAlt.addEventListener('click', () => {
                    trackEvent('account_compare_alt_click', { broker: altBroker.id });
                });
            }
        });
    </script>
</Layout>
