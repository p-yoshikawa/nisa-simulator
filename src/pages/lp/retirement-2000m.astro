---
import Layout from '../../layouts/Layout.astro';
import FAQSection from '../../components/FAQSection.astro';

// SEO Settings
const title = "老後2000万円は新NISAで足りる？積立シミュレーション試算";
const description = "話題になった「老後2000万円問題」は新NISAで解決できる？毎月いくら積み立てれば2000万円に到達するのか、年数や利回りに応じた資産形成シミュレーションを解説します。";

// FAQ Data
const faqs = [
  {
    q: "本当に老後2000万円が必要なのですか？",
    a: "もらえる年金額や希望する生活水準により必要な額は個人差があります。あくまで一つの目安として捉え、ご自身の家計状況を見つめ直すことが良いでしょう。"
  },
  {
    q: "老後資金作りは新NISAとiDeCoどちらが良いですか？",
    a: "資金拘束の有無や所得控除のメリットを天秤にかけ、資金に余裕があれば両方を併用し、難しければ引き出し自由な新NISAを優先する方が多いです。"
  },
  {
    q: "2000万円貯まれば老後は安心ですか？",
    a: "医療費や介護費などインフレリスクや予期せぬ支出への備えも重要です。まとまった資産を取り崩しながら運用を続ける視点も大切になります。"
  }
];
---

<Layout title={title} description={description}>
    <div style="margin-bottom: 2rem;">
        <h1 style="font-size: 1.5rem; color: var(--text-main); line-height: 1.4; margin-bottom: 1rem;">
            老後2000万円は新NISAで足りる？積立シミュレーション試算
        </h1>
        <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem;">
            金融庁の報告書を機に話題となった「老後2000万円問題」。この目標額に対して、新NISAの積立投資を活用した場合、毎月どのくらい積み立てれば到達できるのかシミュレーションしてみましょう。
        </p>
    </div>

    <!-- 結論セクション -->
    <section class="card" style="margin-bottom: 2rem; background-color: var(--bg-body); border: none;">
        <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-main);">
            この記事の結論
        </h2>
        <ul style="list-style-type: disc; padding-left: 1.5rem; color: var(--text-main); line-height: 1.8; font-size: 0.95rem;">
            <li>運用期間が長ければ長いほど（20年〜30年）、<strong>毎月3万円前後の少額積立でも2,000万円を達成できる可性能</strong>が高まります。</li>
            <li>「つみたて投資枠」だけでなく、成長の早い投資信託などで<strong>「成長投資枠」を併用する</strong>ことも目標達成への近道になります。</li>
        </ul>
    </section>

    <!-- シミュレーション事例 -->
    <section class="card" style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">
            老後2000万円を目指す積立シミュレーション
        </h2>
        
        <div style="margin-bottom: 1.5rem;">
            <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.5rem;">【前提条件】</p>
            <ul style="font-size: 0.9rem; color: var(--text-muted); padding-left: 1.5rem; margin-bottom: 1rem;">
                <li>目標金額：約2,000万円</li>
                <li>想定利回り：年利5%とした場合</li>
            </ul>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
            <div style="border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem;">
                <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 0.5rem;">運用期間が20年（45歳〜）の場合</h3>
                <p style="font-size: 0.95rem; color: var(--text-main); margin-bottom: 0.5rem;">必要な毎月の積立額目安：<strong style="font-size: 1.2rem;">約5万円</strong></p>
                <p style="font-size: 0.85rem; color: var(--text-muted);">（20年継続で元本1,200万円＋運用益により約2,000万円到達）</p>
            </div>
            
            <div style="border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem;">
                <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 0.5rem;">運用期間が30年（35歳〜）の場合</h3>
                <p style="font-size: 0.95rem; color: var(--text-main); margin-bottom: 0.5rem;">必要な毎月の積立額目安：<strong style="font-size: 1.2rem;">約2.5万円</strong></p>
                <p style="font-size: 0.85rem; color: var(--text-muted);">（30年継続で元本900万円＋運用益により約2,000万円到達）</p>
            </div>
        </div>
        <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--text-muted);">
            ※これらはあくまで傾向としての例であり、将来の運用成果を予測・保証するものではありません。
        </p>
    </section>

    <!-- ボトムCTA -->
    <div style="text-align: center; margin-bottom: 3rem; background-color: white; padding: 2rem; border-radius: 8px; border: 1px solid var(--primary);">
        <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main);">
            自分の目標に合わせた条件で試算してみましょう
        </h2>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.5rem;">
            シミュレーターを使って、いつ頃2000万円に到達しそうか確認できます。
        </p>
        <a href="/nisa-tsumitate?monthly=30000&years=25&return=5" class="track-outbound" style="display: inline-block; background-color: var(--primary); color: white; padding: 1rem 2rem; border-radius: 8px; font-weight: bold; text-decoration: none;">
            積立シミュレーションへ（無料）
        </a>
    </div>

    <!-- 証券口座比較への自然導線 -->
    <div style="text-align: center; margin-bottom: 2rem;">
        <p style="font-size: 0.95rem; color: var(--text-main); margin-bottom: 0.5rem; font-weight: bold;">💡 実際に新NISAを始める場合、証券口座の比較も重要です。</p>
        <a href="/account-compare" style="color: var(--primary); text-decoration: underline; font-weight: bold;">
            → 新NISA対応のおすすめ証券会社を比較する
        </a>
    </div>

    <!-- FAQ統合と構造化データ出力 -->
    <div style="max-width: 800px; margin: 0 auto; padding: 0 1rem; margin-bottom: 3rem;">
        <h2 style="font-size: 1.25rem; font-weight: 700; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;">
            よくある質問
        </h2>
        <FAQSection faqs={faqs} />
    </div>

    <!-- 関連リンク -->
    <section>
        <h2 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main);">関連シミュレーション</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
            <a href="/lp/40s-is-it-late" style="display: block; padding: 1rem; background: white; border: 1px solid var(--border-color); border-radius: 8px; text-decoration: none; color: var(--text-main); font-weight: bold; font-size: 0.9rem;">
                📈 40代から新NISAは遅い？
            </a>
            <a href="/nisa-withdraw" style="display: block; padding: 1rem; background: white; border: 1px solid var(--border-color); border-radius: 8px; text-decoration: none; color: var(--text-main); font-weight: bold; font-size: 0.9rem;">
                📉 増やした老後資金の取り崩し試算
            </a>
            <a href="/lp/nisa-vs-ideco" style="display: block; padding: 1rem; background: white; border: 1px solid var(--border-color); border-radius: 8px; text-decoration: none; color: var(--text-main); font-weight: bold; font-size: 0.9rem;">
                📊 新NISAとiDeCoどっち？比較
            </a>
        </div>
    </section>
</Layout>
